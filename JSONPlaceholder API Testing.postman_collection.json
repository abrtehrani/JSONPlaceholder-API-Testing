  "item": [
    {
      "name": "GET - List Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse Response\r",
              "let response = pm.response.json();\r",
              "\r",
              "// 1. Status Code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Response is an Array\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    pm.expect(response).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "// 3. Total Number of Posts\r",
              "pm.test(\"There are 100 posts\", function () {\r",
              "    pm.expect(response.length).to.eql(100);\r",
              "});\r",
              "\r",
              "// 4. Required Fields\r",
              "pm.test(\"First post has required fields\", function () {\r",
              "    pm.expect(response[0]).to.have.property(\"userId\");\r",
              "    pm.expect(response[0]).to.have.property(\"id\");\r",
              "    pm.expect(response[0]).to.have.property(\"title\");\r",
              "    pm.expect(response[0]).to.have.property(\"body\");\r",
              "});\r",
              "\r",
              "// 5. Data Types\r",
              "pm.test(\"First post has correct data types\", function () {\r",
              "    pm.expect(response[0].userId).to.be.a(\"number\");\r",
              "    pm.expect(response[0].id).to.be.a(\"number\");\r",
              "    pm.expect(response[0].title).to.be.a(\"string\");\r",
              "    pm.expect(response[0].body).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "// 6. Response Time\r",
              "pm.test(\"Response time is less than 1000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "// 7. Title is not Empty\r",
              "pm.test(\"Title is not empty\", function () {\r",
              "    pm.expect(response[0].title).to.not.be.empty;\r",
              "});\r",
              "\r",
              "// 8. Body is not Empty\r",
              "pm.test(\"Body is not empty\", function () {\r",
              "    pm.expect(response[0].body).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
